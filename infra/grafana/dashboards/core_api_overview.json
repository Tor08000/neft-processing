{
  "uid": "core-api-overview",
  "title": "Core API Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Core API HTTP request rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{service=\"core-api\"}[1m])",
          "legendFormat": "requests/sec"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      }
    }
  ]
}
