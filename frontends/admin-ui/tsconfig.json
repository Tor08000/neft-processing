{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client", "react", "react-dom", "./types/vitest"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src", "types", "../shared/brand", "../shared/lib"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/stubs/**",
    "types/react-query.d.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
