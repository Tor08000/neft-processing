# Local development defaults. Copy to .env and change secrets for non-local usage.
APP_ENV=dev
NEFT_ENV=dev
GATEWAY_BASE_URL=http://localhost

POSTGRES_USER=neft
POSTGRES_PASSWORD=change-me
POSTGRES_DB=neft
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
POSTGRES_INITDB_ARGS=--auth=scram-sha-256
DATABASE_URL=postgresql+psycopg://neft:change-me@postgres:5432/neft

REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_DEFAULT_QUEUE=celery
CELERY_TIMEZONE=Europe/Moscow
FLOWER_BASIC_AUTH=change-me:change-me

JWT_SECRET=change-me
PASSWORD_PEPPER=change-me
AUTH_HOST_MODE=external
AUTH_DEFAULT_TENANT_CODE=neft
NEFT_AUTH_ISSUER=neft-auth
NEFT_AUTH_AUDIENCE=neft-admin
NEFT_CLIENT_AUDIENCE=neft-client
NEFT_PARTNER_AUDIENCE=neft-partner
AUTH_PRIVATE_KEY_PATH=/data/keys/private.pem
AUTH_PUBLIC_KEY_PATH=/data/keys/public.pem
AUTH_PUBLIC_KEY_URL=http://auth-host:8000/api/v1/auth/public-key
AUTH_JWKS_URL=http://auth-host:8000/api/v1/auth/.well-known/jwks.json
ADMIN_PUBLIC_KEY_URL=http://auth-host:8000/api/v1/auth/public-key

DEV_SEED_USERS=1
NEFT_BOOTSTRAP_ENABLED=1
NEFT_BOOTSTRAP_ADMIN_EMAIL=admin@neft.local
NEFT_BOOTSTRAP_ADMIN_PASSWORD=Neft123!
NEFT_BOOTSTRAP_ADMIN_ROLES=ADMIN,PLATFORM_ADMIN,SUPERADMIN
NEFT_BOOTSTRAP_CLIENT_EMAIL=client@neft.local
NEFT_BOOTSTRAP_CLIENT_PASSWORD=Client123!
NEFT_BOOTSTRAP_CLIENT_ROLES=CLIENT_OWNER
NEFT_BOOTSTRAP_PARTNER_EMAIL=partner@neft.local
NEFT_BOOTSTRAP_PARTNER_PASSWORD=Partner123!
NEFT_BOOTSTRAP_PARTNER_ROLES=PARTNER_OWNER

MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
NEFT_S3_ENDPOINT=http://minio:9000
NEFT_S3_ACCESS_KEY=change-me
NEFT_S3_SECRET_KEY=change-me
NEFT_S3_REGION=us-east-1
NEFT_S3_BUCKET=neft
NEFT_S3_BUCKET_INVOICES=neft-invoices
NEFT_S3_BUCKET_PAYOUTS=neft-payouts
NEFT_S3_BUCKET_DOCUMENTS=neft-documents
NEFT_S3_BUCKET_ACCOUNTING_EXPORTS=accounting-exports

CLICKHOUSE_DB=neft_geo
CLICKHOUSE_URL=http://clickhouse:8123
BI_CLICKHOUSE_ENABLED=1

CORE_API_URL=http://core-api:8000
AUTH_HOST_URL=http://auth-host:8000
AI_SERVICE_URL=http://ai-service:8000
DOCUMENT_SERVICE_ENABLED=1
DOCUMENT_SERVICE_URL=http://document-service:8000
INTEGRATION_HUB_URL=http://integration-hub:8000
INTEGRATION_HUB_DATABASE_URL=postgresql+psycopg://neft:change-me@postgres:5432/neft
INTEGRATION_HUB_INTERNAL_TOKEN=change-me
INTEGRATION_HUB_AUTO_CREATE_SCHEMA=true
WEBHOOK_INTAKE_SECRET=change-me
WEBHOOK_ALLOW_UNSIGNED=true
LOGISTICS_SERVICE_ENABLED=1
LOGISTICS_SERVICE_URL=http://logistics-service:8000
LOGISTICS_PROVIDER=integration_hub
LOGISTICS_COMPUTE_PROVIDER=osrm
LOGISTICS_INTERNAL_TOKEN=change-me
CRM_DATABASE_URL=postgresql+psycopg://neft:change-me@postgres:5432/neft

DIADOK_MODE=sandbox
SBIS_MODE=sandbox
NOTIFICATIONS_MODE=sandbox
EMAIL_PROVIDER_MODE=sandbox
OTP_PROVIDER_MODE=sandbox
BANK_API_MODE=sandbox
ERP_1C_MODE=sandbox
FUEL_PROVIDER_MODE=sandbox
LOGISTICS_PROVIDER_MODE=sandbox
OTP_ENABLED=1
OTP_TEST_MODE=1
PROVIDER_X_MODE=degraded
USE_STUB_EDO=0
USE_STUB_CRM=0
USE_MOCK_LOGISTICS=0
NEFT_EMAIL_MODE=mailpit
NEFT_EMAIL_HOST=mailpit
NEFT_EMAIL_PORT=1025
SMTP_HOST=mailpit
SMTP_PORT=1025

VITE_API_BASE_URL=/api
VITE_CORE_API_BASE=/api/core
VITE_AUTH_API_BASE=/api/v1/auth
VITE_AI_API_BASE=/api/ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
