POSTGRES_USER=neft
POSTGRES_PASSWORD=change-me
POSTGRES_DB=neft
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
POSTGRES_INITDB_ARGS=--auth=scram-sha-256
DATABASE_URL=postgresql+psycopg://neft:change-me@postgres:5432/neft
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_DEFAULT_QUEUE=celery
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300
FLOWER_BASIC_AUTH=change-me:change-me
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRES_MIN=60
REFRESH_TOKEN_EXPIRES_DAYS=15
PASSWORD_PEPPER=change-me
CORE_API_URL=http://core-api:8000
AI_SERVICE_URL=http://ai-service:8000
ADMIN_PUBLIC_KEY_URL=http://auth-host:8000/api/v1/auth/public-key
ADMIN_JWT_ISSUER=neft-auth
ADMIN_JWT_AUDIENCE=neft-admin
NEFT_DEMO_ADMIN_EMAIL=admin@example.com
NEFT_DEMO_ADMIN_PASSWORD=change-me
NEFT_DEMO_CLIENT_EMAIL=client@neft.local
NEFT_DEMO_CLIENT_PASSWORD=change-me
NEFT_DEMO_CLIENT_FULL_NAME=Demo Client
NEFT_DEMO_CLIENT_ID=demo-client
NEFT_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
NEFT_BOOTSTRAP_ADMIN_PASSWORD=admin
NEFT_BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin
NEFT_BOOTSTRAP_ADMIN_ROLES=ADMIN,PLATFORM_ADMIN,SUPERADMIN
NEFT_BOOTSTRAP_CLIENT_EMAIL=client@neft.local
NEFT_BOOTSTRAP_CLIENT_PASSWORD=client
NEFT_BOOTSTRAP_CLIENT_FULL_NAME=Demo Client
NEFT_BOOTSTRAP_CLIENT_ROLES=CLIENT_OWNER
NEFT_BOOTSTRAP_PARTNER_EMAIL=partner@neft.local
NEFT_BOOTSTRAP_PARTNER_PASSWORD=partner
NEFT_BOOTSTRAP_PARTNER_FULL_NAME=Demo Partner
NEFT_BOOTSTRAP_PARTNER_ROLES=PARTNER_OWNER
NEFT_BOOTSTRAP_ENABLED=1
NEFT_BOOTSTRAP_PASSWORD_VERSION=1
NEFT_AUTH_ISSUER=neft-auth
NEFT_AUTH_AUDIENCE=neft-admin
AUTH_KEY_DIR=/data/keys
AUTH_PRIVATE_KEY_PATH=/data/keys/private.pem
AUTH_PUBLIC_KEY_PATH=/data/keys/public.pem
VITE_API_BASE_URL=http://localhost
VITE_CORE_API_BASE=/api/core
VITE_AUTH_API_BASE=/api/auth
VITE_AI_API_BASE=/api/ai
# Override to call auth-host through a custom gateway host/port during local dev
ADMIN_AUTH_URL=http://localhost/api/auth/v1/auth/login
# AUTH_JWT_PRIVATE_KEY=...   # optional: RSA private key (PEM)
# AUTH_JWT_PUBLIC_KEY=...    # optional: RSA public key (PEM)
LOG_LEVEL=INFO
FEATURE_FLAGS=ai_scorer:on,ai_anomaly:off
PYTHONUNBUFFERED=1
# MUST be overridden in real .env
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
NEFT_S3_BUCKET=neft
NEFT_S3_BUCKET_INVOICES=neft-invoices
NEFT_S3_ACCESS_KEY=change-me
NEFT_S3_SECRET_KEY=change-me
NEFT_S3_ENDPOINT=http://minio:9000
NEFT_S3_REGION=us-east-1
NEFT_S3_BUCKET_PUBLIC=0
NEFT_S3_BUCKET_INVOICES_PUBLIC=0
MINIO_INIT_RETRIES=60
MINIO_INIT_RETRY_DELAY=2
NEFT_S3_PUBLIC_URL_BASE=
S3_ENDPOINT_URL=http://minio:9000
NEFT_INVOICE_PDF_TEMPLATE_VERSION=1
NEFT_INVOICE_MONTHLY_ENABLED=true
NEFT_PDF_AUTO_GENERATE=1
# Audit signing
AUDIT_SIGNING_MODE=local
AUDIT_SIGNING_REQUIRED=false
AUDIT_SIGNING_ALG=ed25519
AUDIT_SIGNING_KEY_ID=local-dev-key-v1
AUDIT_SIGNING_PRIVATE_KEY_B64=
AUDIT_SIGNING_PUBLIC_KEYS_JSON=
AUDIT_SIGNING_PUBLIC_KEYS_CACHE_SECONDS=3600
# AWS KMS
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_ENDPOINT=
AWS_KMS_VERIFY_MODE=local
# Vault Transit
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_TRANSIT_MOUNT=transit
VAULT_TRANSIT_KEY=
VAULT_VERIFY_MODE=vault
# Object Lock
S3_OBJECT_LOCK_ENABLED=false
S3_OBJECT_LOCK_MODE=GOVERNANCE
S3_OBJECT_LOCK_RETENTION_DAYS=180
S3_OBJECT_LOCK_LEGAL_HOLD=false
