POSTGRES_USER=neft
POSTGRES_PASSWORD=neft
POSTGRES_DB=neft
DATABASE_URL=postgresql+psycopg://neft:neft@postgres:5432/neft
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_DEFAULT_QUEUE=celery
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300
FLOWER_BASIC_AUTH=admin:change-me
JWT_SECRET=dev-secret
ACCESS_TOKEN_EXPIRES_MIN=60
REFRESH_TOKEN_EXPIRES_DAYS=15
PASSWORD_PEPPER=dev-pepper
CORE_API_URL=http://core-api:8000
AI_SERVICE_URL=http://ai-service:8000
ADMIN_PUBLIC_KEY_URL=http://auth-host:8000/api/v1/auth/public-key
NEFT_DEMO_ADMIN_EMAIL=admin@example.com
NEFT_DEMO_ADMIN_PASSWORD=admin123
NEFT_DEMO_CLIENT_EMAIL=client@neft.local
NEFT_DEMO_CLIENT_PASSWORD=client
NEFT_DEMO_CLIENT_FULL_NAME=Demo Client
NEFT_DEMO_CLIENT_ID=demo-client
VITE_ADMIN_BASE_PATH=/admin/
# Override to call auth-host through a custom gateway host/port during local dev
ADMIN_AUTH_URL=http://localhost/api/auth/api/v1/auth/login
# AUTH_JWT_PRIVATE_KEY=...   # optional: RSA private key (PEM)
# AUTH_JWT_PUBLIC_KEY=...    # optional: RSA public key (PEM)
LOG_LEVEL=INFO
FEATURE_FLAGS=ai_scorer:on,ai_anomaly:off
PYTHONUNBUFFERED=1
